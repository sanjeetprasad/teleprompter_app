{
  "expo": {
    "name": "Teleprompter Pro",
    "slug": "teleprompter-pro",
    "scheme": "teleprompterpro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0E12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.teleprompterpro"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0E12"
      },
      "package": "com.example.teleprompterpro"
    },
    "plugins": ["expo-router", "expo-sqlite"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
